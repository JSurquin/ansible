# Virtual Host pour {{ item.server_name }}
# Généré par Ansible le {{ ansible_facts['date_time']['date'] }}

# Bloc de configuration du serveur virtuel
server {
    # Port d'écoute IPv4
    listen {{ item.port | default(nginx_listen_port) }};
{% if nginx_listen_ipv6 %}
    # Port d'écoute IPv6
    listen [::]:{{ item.port | default(nginx_listen_port) }};
{% endif %}

    # Nom de domaine du vhost
    server_name {{ item.server_name }};
    
    # Répertoire racine des fichiers du site
    root {{ item.root }};
    # Fichiers index par ordre de priorité
    index index.html index.htm index.nginx-debian.html;

    # Logs spécifiques à ce vhost
    access_log {{ nginx_log_path }}/{{ item.server_name }}-access.log;
    error_log {{ nginx_log_path }}/{{ item.server_name }}-error.log;

    # Configuration principale - racine du site
    location / {
        # Essayer fichier, puis répertoire, sinon 404
        try_files $uri $uri/ =404;
    }

    # Health check endpoint - vérification santé
    location /health {
        # Ne pas logger ces requêtes
        access_log off;
        # Retourner code 200 avec message "OK"
        return 200 "OK\n";
        # Définir le type MIME de la réponse
        add_header Content-Type text/plain;
    }

    # Status endpoint - statistiques Nginx (optionnel)
    location /status {
        # Activer le module stub_status
        stub_status on;
        # Ne pas logger ces requêtes
        access_log off;
        # Autoriser uniquement localhost
        allow 127.0.0.1;
        # Interdire tous les autres accès
        deny all;
    }

{% if item.extra_config is defined %}
    # Configuration supplémentaire
    {{ item.extra_config | indent(4) }}
{% endif %}
}
