# Configuration Nginx générée par Ansible
# Rôle: nginx
# Généré le: {{ ansible_facts['date_time']['iso8601'] }}

# Utilisateur sous lequel Nginx s'exécute
user {{ nginx_user }};
# Nombre de processus workers
worker_processes {{ nginx_worker_processes }};
# Fichier PID pour la gestion du processus
pid /run/nginx.pid;
# Inclure les modules activés
include /etc/nginx/modules-enabled/*.conf;

# Bloc de configuration des événements
events {
    # Connexions simultanées par worker
    worker_connections {{ nginx_worker_connections }};
    # Option : accepter plusieurs connexions à la fois (commenté)
    # multi_accept on;
}

# Bloc de configuration HTTP
http {
    ##
    # Basic Settings
    ##
    # Optimisation : utiliser sendfile() pour l'envoi de fichiers
    sendfile on;
    # Optimisation : envoyer les headers et début de fichier ensemble
    tcp_nopush on;
    # Optimisation : désactiver l'algorithme de Nagle
    tcp_nodelay on;
    # Durée de vie des connexions persistantes
    keepalive_timeout {{ nginx_keepalive_timeout }};
    # Taille maximale de la table de hachage des types MIME
    types_hash_max_size 2048;
    # Taille maximale des requêtes (uploads)
    client_max_body_size {{ nginx_client_max_body_size }};

    # Masquer la version de Nginx (commenté)
    # server_tokens off;
    # Taille bucket pour noms de serveurs (commenté)
    # server_names_hash_bucket_size 64;
    # Ne pas utiliser server_name dans redirections (commenté)
    # server_name_in_redirect off;

    # Inclure les types MIME standards
    include /etc/nginx/mime.types;
    # Type MIME par défaut pour fichiers inconnus
    default_type application/octet-stream;

    ##
    # SSL Settings
    ##
    # Protocoles SSL/TLS autorisés (sécurisés uniquement)
    ssl_protocols TLSv1.2 TLSv1.3;
    # Préférer l'ordre des ciphers du serveur
    ssl_prefer_server_ciphers on;

    ##
    # Logging Settings
    ##
    # Fichier de log des accès HTTP
    access_log {{ nginx_log_path }}/access.log;
    # Fichier de log des erreurs
    error_log {{ nginx_log_path }}/error.log;

    ##
    # Gzip Settings
    ##
    # Activer ou désactiver gzip selon variable
    gzip {{ 'on' if nginx_gzip_enabled else 'off' }};
{% if nginx_gzip_enabled %}
    # Ajouter header Vary: Accept-Encoding
    gzip_vary on;
    # Compresser aussi les réponses proxy
    gzip_proxied any;
    # Niveau de compression (1-9, 6 = bon compromis)
    gzip_comp_level 6;
    # Types MIME à compresser
    gzip_types text/plain text/css text/xml text/javascript 
               application/json application/javascript application/xml+rss 
               application/rss+xml font/truetype font/opentype 
               application/vnd.ms-fontobject image/svg+xml;
{% endif %}

    ##
    # Virtual Host Configs
    ##
    # Inclure tous les vhosts actifs
    include {{ nginx_vhost_enabled_path }}/*;
}
