# Configuration Nginx générée par Ansible
# Serveur: {{ inventory_hostname }}
# Date: {{ ansible_facts['date_time']['date'] }} {{ ansible_facts['date_time']['time'] }}

# Utilisateur sous lequel Nginx s'exécute
user www-data;
# Nombre de workers (auto par défaut)
worker_processes {{ nginx_worker_processes | default('auto') }};
# Fichier contenant le PID du processus principal
pid /run/nginx.pid;

# Bloc de configuration des événements
events {
    # Connexions simultanées par worker
    worker_connections {{ nginx_config.worker_connections }};
}

# Bloc de configuration HTTP principal
http {
    # Configuration de base - paramètres de base
    # Optimisation : utiliser sendfile() pour l'envoi de fichiers
    sendfile on;
    # Optimisation : envoyer headers et fichier ensemble
    tcp_nopush on;
    # Optimisation : désactiver l'algorithme de Nagle
    tcp_nodelay on;
    # Durée de vie des connexions persistantes en secondes
    keepalive_timeout 65;
    # Taille max de la table de hachage des types MIME
    types_hash_max_size 2048;
    # Taille max des requêtes (uploads)
    client_max_body_size {{ nginx_config.client_max_body_size }};

    # MIME types - inclure la liste des types MIME standards
    include /etc/nginx/mime.types;
    # Type par défaut pour fichiers inconnus
    default_type application/octet-stream;

    # Logs
    # Log des requêtes HTTP
    access_log /var/log/nginx/access.log;
    # Log des erreurs
    error_log /var/log/nginx/error.log;

    # Compression gzip
    # Activer la compression gzip
    gzip on;
    # Désactiver pour Internet Explorer 6 (bug connu)
    gzip_disable "msie6";

    # Virtual Host - configuration du vhost
    server {
        # Port d'écoute HTTP
        listen {{ nginx_config.port }};
        # Nom de domaine du serveur
        server_name {{ inventory_hostname }};

        # Répertoire racine des fichiers du site
        root /var/www/html;
        # Fichier index par défaut
        index index.html;

        # Configuration pour la racine du site
        location / {
            # Essayer fichier, puis répertoire, sinon 404
            try_files $uri $uri/ =404;
        }

        # Health check - endpoint de vérification santé
        location /health {
            # Ne pas logger ces requêtes
            access_log off;
            # Retourner code 200 avec message "OK"
            return 200 "OK";
            # Type de contenu : texte brut
            add_header Content-Type text/plain;
        }
    }
}
